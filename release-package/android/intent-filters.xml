<!-- Intent filters to be injected into the main <activity> in AndroidManifest.xml.
     This fragment is inserted by release-package/android/inject-intent-filters.py
     during the CI build (after "npx cap sync android").

     These filters allow PaceRead to appear in the Android "Open with" chooser
     when a user opens a supported document file from any app. -->

<!-- PDF -->
<intent-filter android:label="@string/app_name">
    <action android:name="android.intent.action.VIEW" />
    <category android:name="android.intent.category.DEFAULT" />
    <category android:name="android.intent.category.BROWSABLE" />
    <data android:scheme="file" android:mimeType="application/pdf" />
    <data android:scheme="content" android:mimeType="application/pdf" />
</intent-filter>

